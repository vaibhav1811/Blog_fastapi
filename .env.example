# ─────────────────────────────────────────────────────────────────────────────
# FastAPI Blog — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# The .env file is git-ignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./blog.db

# ── Auth / JWT ────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Email — Sender Address ────────────────────────────────────────────────────
# LOCAL DEV  → use Resend's free sandbox sender (works with any API key, no domain needed)
MAIL_FROM=onboarding@resend.dev
# PRODUCTION → use your own verified domain address in Resend dashboard
# MAIL_FROM=noreply@yourdomain.com

# ── Email — Resend API (Priority 1) ───────────────────────────────────────────
# Get your key at: https://resend.com/api-keys
# LOCAL DEV: paste your test key below (keep it in .env, never commit)
# PRODUCTION: set this as an environment variable on your hosting platform
RESEND_API_KEY=re_your_resend_api_key_here

# ── Email — Brevo API (Priority 2, optional fallback) ────────────────────────
# Leave blank to skip; Resend takes priority when both are set
# BREVO_API_KEY=

# ── Email — SMTP (Priority 3, last-resort fallback) ──────────────────────────
# Only used when neither RESEND_API_KEY nor BREVO_API_KEY is set
MAIL_SERVER=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_USE_TLS=true

# ── AWS S3 / Object Storage ───────────────────────────────────────────────────
S3_BUCKET_NAME=your-bucket-name
S3_REGION=eu-north-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
# S3_ENDPOINT_URL=           # Only needed for custom S3-compatible endpoints

# ── Frontend URL ──────────────────────────────────────────────────────────────
# IMPORTANT: Do NOT add a trailing slash — it will cause double-slash URLs in emails.
# LOCAL DEV:
FRONTEND_URL=http://localhost:8000
# PRODUCTION:
# FRONTEND_URL=https://your-app.onrender.com

# ── Environment & API Docs Visibility ─────────────────────────────────────────
# Controls whether Swagger UI (/docs) and ReDoc (/redoc) are accessible.
# LOCAL DEV: leave as "development" — docs are always visible.
APP_ENV=development

# PRODUCTION: set to "production" on your hosting platform (Render, Railway, etc.)
# This will fully disable /docs and /redoc unless DOCS_ALLOWED_IPS is set.
# APP_ENV=production

# Comma-separated list of IPs allowed to access API docs even in production.
# Use your team's static IP or VPN exit node IP.
# Leave empty (or omit) to block docs for everyone in production.
# DOCS_ALLOWED_IPS=203.0.113.10,198.51.100.5
